{
  "name": "shelly-homematic",
  "version": "0.10.1",
  "description": "A bridge that exposes Shelly devices to the Homematic CCU3/RaspberryMatic as virtual HM devices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:addon": "bash scripts/build-addon.sh",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint 'src/**/*.ts'",
    "test": "jest",
    "dev:test": "ts-node src/index.ts --config=config.test.json"
  },
  "keywords": [
    "shelly",
    "homematic",
    "ccu3",
    "raspberrymatic",
    "smart-home",
    "bridge",
    "xmlrpc"
  ],
  "author": "Nils Motsch",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "winston": "^3.11.0",
    "ws": "^8.18.0",
    "xmlrpc": "^1.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@types/xmlrpc": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nilsmotsch/shelly-homematic"
  }
}
